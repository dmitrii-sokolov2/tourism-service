{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object", 
    "properties": {
        "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 100
        },
        "country": {
            "type": "string",
            "minLength": 2,
            "maxLength": 50
        },
        "description": {
            "type": "string"
        },
        "price": {
            "type": "number",
            "minimum": 0
        },
        "duration_days": {
            "type": "integer", 
            "minimum": 1
        }
    },
    "required": ["name", "country"],
    "additionalProperties": false
}