{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 100
        },
        "email": {
            "type": "string",
            "format": "email"
        },
        "phone": {
            "type": "string",
            "pattern": "^\\+?[\\d\\s\\-\\(\\)]+$"
        }
    },
    "required": ["name", "email"],
    "additionalProperties": false
}