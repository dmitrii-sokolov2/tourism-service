{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "destination_id": {
            "type": "integer",
            "minimum": 1
        },
        "start_date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "end_date": {
            "type": "string", 
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "available_slots": {
            "type": "integer",
            "minimum": 0
        },
        "price": {
            "type": "number",
            "minimum": 0
        },
        "is_active": {
            "type": "boolean"
        }
    },
    "required": ["destination_id", "start_date", "end_date", "price"],
    "additionalProperties": false
}